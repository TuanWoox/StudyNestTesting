        "title": "Learning C# with Editor.js",
        "content": "{\"time\": 1694025600000, \"blocks\": [{\"id\": \"block1\", \"data\": {\"text\": \"C# Basics\", \"level\": 2}, \"type\": \"header\"}, {\"id\": \"block2\", \"data\": {\"text\": \"C# is a modern, object-oriented programming language developed by Microsoft.\"}, \"type\": \"paragraph\"}, {\"id\": \"block3\", \"data\": {\"code\": \"using System;\\n\\nclass Program\\n{\\n    static void Main()\\n    {\\n        Console.WriteLine(\\\"Hello, World!\\\");\\n    }\\n}\"}, \"type\": \"code\"}, {\"id\": \"block4\", \"data\": {\"items\": [{\"text\": \"Install .NET SDK\", \"checked\": true}, {\"text\": \"Set up Visual Studio Code\", \"checked\": false}, {\"text\": \"Write your first program\", \"checked\": false}]}, \"type\": \"checklist\"}, {\"id\": \"block5\", \"data\": {\"file\": {\"url\": \"https://placekitten.com/600/300\"}, \"caption\": \"Cute kitten while learning C#\", \"stretched\": false, \"withBorder\": true, \"withBackground\": false}, \"type\": \"image\"}], \"version\": \"2.29.1\"}",
